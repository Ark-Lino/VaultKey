{
  "manifest_version": 3,
  "name": "VaultKey",
  "version": "1.0.0",
  "description": "Offline TOTP Authenticator — Generate 2FA codes without network requests.",
  "browser_specific_settings": {
    "gecko": {
      "id": "vaultkey@extension",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["storage", "clipboardWrite", "activeTab", "alarms"],
  "host_permissions": [],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "VaultKey"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'none'"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
